{
  "name": "shofy-next-js",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "browserslist": {
    "production": [
      "chrome 111",
      "edge 111",
      "firefox 111",
      "safari 16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:inspect": "next dev --webpack --inspect",
    "build": "cross-env CI=false next build --webpack",
    "start": "next start",
    "devtools:react": "react-devtools",
    "lhci": "lhci autorun",
    "playwright:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright install chromium",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "test:smoke": "cross-env PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --grep @smoke",
    "test:e2e:headed": "cross-env PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --headed",
    "test:e2e:prod": "cross-env PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_SERVER_COMMAND=\"npm run start\" playwright test",
    "build:force": "cross-env DISABLE_ESLINT_PLUGIN=true CI=false next build --webpack",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "analyze:nextjs": "next experimental-analyze",
    "analyze:nextjs:output": "next experimental-analyze --output",
    "build:verify": "node scripts/verify-build-optimizations.js",
    "test-sitemap-page": "node scripts/test-sitemap-page.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-sitemap": "node scripts/check-sitemap.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "test-sitemap": "node scripts/test-full-sitemap.js",
    "test-llm": "node scripts/test-llm-txt.js",
    "check-seo": "node scripts/check-seo-headers.js",
    "test-security": "node scripts/test-security-headers.js",
    "test-robots": "node scripts/test-robots-txt.js",
    "test-api": "node scripts/test-api.js",
    "mcp:purgecss": "node scripts/mcp-purgecss-server.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@popperjs/core": "^2.11.8",
    "@sentry/nextjs": "^10.43.0",
    "@vercel/otel": "^2.1.1",
    "@vercel/speed-insights": "^1.3.1",
    "bootstrap": "^5.3.2",
    "dayjs": "^1.11.20",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.0.0",
    "next": "^16.1.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.57.0",
    "react-icons": "^5.5.0",
    "react-modal": "^3.16.1",
    "react-toastify": "^11.0.5",
    "sass": "^1.98.0",
    "swiper": "^11.2.8",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.21",
    "critters-webpack-plugin": "^3.0.2",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.2",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.5",
    "fast-glob": "^3.3.3",
    "knip": "^5.86.0",
    "postcss": "^8.5.6",
    "postcss-preset-env": "^10.2.4",
    "prettier": "^3.6.0",
    "purgecss": "^8.0.0",
    "react-devtools": "^7.0.1",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "zod": "^4.3.6"
  }
}


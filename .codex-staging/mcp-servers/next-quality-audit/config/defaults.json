{
  "protectedPathPatterns": [
    "src/app/**/page.*",
    "src/app/**/layout.*",
    "src/app/**/template.*",
    "src/app/**/loading.*",
    "src/app/**/error.*",
    "src/app/**/not-found.*",
    "src/app/**/global-error.*",
    "src/app/**/route.*",
    "src/pages/**",
    "app/**/page.*",
    "app/**/layout.*",
    "app/**/template.*",
    "app/**/loading.*",
    "app/**/error.*",
    "app/**/not-found.*",
    "app/**/route.*",
    "pages/**",
    "middleware.ts",
    "middleware.js",
    "next.config.*"
  ],
  "protectedAreaKeywords": [
    "auth",
    "login",
    "register",
    "checkout",
    "cart",
    "wishlist",
    "account",
    "profile",
    "pricing",
    "payment",
    "order",
    "seo",
    "schema",
    "analytics",
    "sitemap",
    "robots",
    "revalidate",
    "api"
  ],
  "clientComponentRiskThresholdBytes": 15000,
  "cssLargeFileThresholdBytes": 40000,
  "bundleLargeChunkThresholdBytes": 120000,
  "heavyClientPackages": {
    "next": "framework-critical",
    "react": "framework-critical",
    "react-dom": "framework-critical",
    "eslint": "framework-critical",
    "typescript": "framework-critical",
    "@next/swc": "framework-critical",
    "@next/swc-wasm-nodejs": "framework-critical",
    "@next/swc-wasm-web": "framework-critical",
    "swiper": "heavy-client",
    "react-icons": "heavy-client",
    "bootstrap": "heavy-client",
    "jspdf": "heavy-client",
    "@sentry/nextjs": "heavy-client",
    "qrcode": "medium-client",
    "react-toastify": "medium-client",
    "@reduxjs/toolkit": "medium-client"
  }
}
